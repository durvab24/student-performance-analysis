import seaborn as sns
import matplotlib.pyplot as plt
import pandas as pd

data=pd.read_csv("student_performance.csv")

print(data.head())

#scatter plot
#math vs reading score
plt.figure(figsize=(7,5))
sns.scatterplot(x="Math_Score", y="Reading_Score", hue="Gender", data=data)
plt.title("Scatter Plot: Math vs Reading Score")
plt.show()

#bar plot
#avd math score by parental education
plt.figure(figsize=(8,5))
sns.barplot(x="Parental_Education", y="Math_Score", data=data, estimator=sum, ci=None)
plt.title("Bar Plot: Total Math Score by Parental Education")
plt.xticks(rotation=45)
plt.show()

#box plot
#distribution of writing scores by gender
plt.figure(figsize=(7,5))
sns.boxplot(x="Gender", y="Writing_Score", data=data)
plt.title("Box Plot: Writing Score Distribution by Gender")
plt.show()

#histogram
#distribution of math scores
plt.figure(figsize=(7,5))
sns.histplot(data["Math_Score"], bins=15, kde=True)
plt.title("Histogram: Math Score Distribution")
plt.show()